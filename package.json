{
  "name": "semantic-release-lerna",
  "version": "0.5.0",
  "description": "semantic-release plugin to publish lerna monorepo packages to npm",
  "keywords": [
    "npm",
    "lerna",
    "publish",
    "registry",
    "semantic-release",
    "version"
  ],
  "homepage": "https://github.com/ext/semantic-release-lerna",
  "bugs": {
    "url": "https://github.com/ext/semantic-release-lerna/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ext/semantic-release-lerna.git"
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/ext"
    }
  ],
  "license": "MIT",
  "author": "David Sveningsson <ext@sidvind.com>",
  "contributors": [
    "Pierre Vanduynslager (https://twitter.com/@pvdlg_)",
    "Stephan Bönnemann <stephan@boennemann.me> (http://boennemann.me)",
    "Gregor Martynus (https://twitter.com/gr2m)"
  ],
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node build.mjs",
    "eslint": "eslint --cache .",
    "eslint:fix": "eslint --cache --fix .",
    "prepack": "release-prepack --bundle",
    "postpack": "release-postpack",
    "prepublishOnly": "release-prepublish --bundle",
    "prettier:check": "prettier --check .",
    "prettier:write": "prettier --write .",
    "postpublish": "release-postpublish",
    "pretest": "npm run eslint && npm run prettier:check",
    "test": "vitest run"
  },
  "prettier": "@html-validate/prettier-config",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@semantic-release/error": "^4.0.0",
    "aggregate-error": "5.0.0",
    "conventional-changelog-angular": "^7.0.0 || ^8.0.0",
    "conventional-changelog-writer": "^7.0.0 || ^8.0.0",
    "conventional-commits-filter": "^5.0.0",
    "conventional-commits-parser": "^7.0.0",
    "cosmiconfig": "^9.0.2",
    "detect-indent": "7.0.2",
    "env-ci": "11.2.0",
    "execa": "9.6.1",
    "get-stream": "9.0.1",
    "globby": "^16.2.0",
    "import-from-esm": "^2.0.0",
    "into-stream": "9.1.0",
    "js-yaml": "^5.2.0",
    "libnpmversion": "^8.0.4",
    "minimatch": "10.2.5",
    "nerf-dart": "1.0.0",
    "normalize-url": "9.0.1",
    "npm-package-arg": "14.0.0",
    "p-map": "^7.0.4",
    "rc": "1.2.8",
    "read-package-up": "12.0.0",
    "registry-auth-token": "^5.1.1",
    "semver": "7.8.5"
  },
  "devDependencies": {
    "@html-validate/eslint-config": "9.8.8",
    "@html-validate/eslint-config-vitest": "9.8.0",
    "@html-validate/prettier-config": "4.1.4",
    "@html-validate/release-scripts": "7.3.1",
    "@types/npmlog": "7.0.0",
    "@types/semver": "7.7.1",
    "@vitest/coverage-v8": "4.1.9",
    "esbuild": "0.28.1",
    "lerna": "9.0.7",
    "npm-pkg-lint": "5.1.10",
    "semantic-release": "25.0.5",
    "stream-buffers": "3.0.3",
    "verdaccio": "6.7.4",
    "vitest": "4.1.9"
  },
  "peerDependencies": {
    "lerna": "^8.0.0 || ^9.0.0",
    "semantic-release": "^24.0.0 || ^25.0.0"
  },
  "engines": {
    "node": "^22.22.2 || ^24.15.0 || >= 26.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "allowScripts": {
    "esbuild": true,
    "nx": false,
    "fsevents": false,
    "unrs-resolver": true
  },
  "externalDependencies": [
    "@actions/core",
    "@semantic-release/error",
    "conventional-changelog-angular",
    "conventional-changelog-writer",
    "cosmiconfig",
    "libnpmversion",
    "registry-auth-token"
  ]
}
